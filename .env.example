# Hollow Man - Environment Configuration
# Copy this file to .env and update the values

# ============================================
# Docker Compose Configuration
# ============================================

# Server Configuration
SERVER_PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# Client Configuration
CLIENT_PORT=3000
VITE_SERVER_URL=http://localhost:3001

# ============================================
# Cloud Deployment URLs
# ============================================

# Update these with your actual deployment URLs
# PROD_SERVER_URL=https://your-server-domain.com
# PROD_CLIENT_URL=https://your-client-domain.com

# ============================================
# GitHub Actions Secrets
# Add these to your GitHub repository settings:
#
# PROD_URL - Production server URL for health checks
# STAGING_URL - Staging server URL for health checks
# GITHUB_TOKEN - Auto-generated, no need to set
